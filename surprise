<!DOCTYPE html>
<html lang="en">
<head>
<meta charset="UTF-8">
<meta name="viewport" content="width=device-width, initial-scale=1.0">
<title>Birthday Surprise</title>

<style>

body{
margin:0;
font-family:Arial, sans-serif;
background:#111;
color:white;
text-align:center;
overflow-x:hidden;
}

/* candle section */

#candlePage{
height:100vh;
display:flex;
flex-direction:column;
justify-content:center;
align-items:center;
}

.candle{
width:40px;
height:120px;
background:#fff;
border-radius:8px;
position:relative;
}

.flame{
width:25px;
height:40px;
background:orange;
border-radius:50%;
position:absolute;
top:-35px;
left:7px;
animation:flicker .15s infinite alternate;
}

@keyframes flicker{
from{transform:scale(1)}
to{transform:scale(1.1)}
}

#count{
font-size:60px;
margin-top:40px;
font-weight:bold;
}

#blow{
font-size:60px;
color:pink;
margin-top:20px;
display:none;
font-weight:bold;
}

/* memes page */

#memesPage{
display:none;
padding:20px;
}

.bigtext{
font-size:32px;
font-weight:bold;
margin-bottom:30px;
}

img{
width:90%;
margin:15px 0;
border-radius:12px;
}

</style>
</head>

<body>

<!-- candle page -->

<div id="candlePage">

<div class="candle">
<div class="flame" id="flame"></div>
</div>

<div id="count">1</div>

<div id="blow">BLOW IT</div>

</div>

<!-- memes page -->

<div id="memesPage">

<div class="bigtext">
HAPPY BIRTHDAY MY LOVE,<br>
I KNOW THIS IS SO BORING BUT MY VARTUAL GIFT
</div>

<img src="https://i.imgur.com/2DhmtJ4.jpeg">
<img src="https://i.imgur.com/5M0Q0sH.jpeg">
<img src="https://i.imgur.com/3ZQ3Z6F.jpeg">
<img src="https://i.imgur.com/VaX0F1B.jpeg">

</div>

<script>

let count = 1

let counter = setInterval(() => {

count++

if(count <= 3){
document.getElementById("count").innerText = count
}

if(count === 4){
document.getElementById("count").innerText = "NOW"
document.getElementById("blow").style.display="block"
clearInterval(counter)
}

},1000)

document.getElementById("blow").onclick = () => {

document.getElementById("flame").style.display="none"

setTimeout(()=>{

document.getElementById("candlePage").style.display="none"
document.getElementById("memesPage").style.display="block"

},800)

}

</script>

</body>
</html>
